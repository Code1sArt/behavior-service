DATABASE_URL="mysql://USER:PASSWORD@HOST:3306/DATABASE"
JWT_SECRET="change-me"
PORT=3000

LINE_CHANNEL_ACCESS_TOKEN=""
LINE_LOGIN_CHANNEL_ID=""
LINE_LOGIN_CHANNEL_SECRET=""

# Server-side deploy script options:
# DEPLOY_DATABASE_MODE=migrate | push | skip
DEPLOY_DATABASE_MODE=migrate

# Optional when the app is managed by PM2 instead of Plesk Passenger:
# APP_PM2_NAME=behavior-service

# Optional when SSH sessions do not load the Plesk Node.js path:
# NODE_BIN_DIR=/opt/plesk/node/24/bin
